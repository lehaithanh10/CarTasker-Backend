# CarTasker Backend — environment variables
#
# Copy to `.env` for local dev. Never commit a populated copy of this file.
# In Fly: set via `flyctl secrets set -a <app> KEY=value`.

# ---- Database ----------------------------------------------------------
# Postgres (Neon in prod/staging; local Postgres in dev).
# Append ?sslmode=require for managed providers.
DATABASE_URL="postgresql://pguser:password@localhost:5432/cartasker_dev"

# ---- Auth --------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=""
AUTH_ACCESS_TOKEN_TTL="15m"     # short-lived access token
AUTH_REFRESH_TOKEN_TTL="7d"     # opaque refresh token (DB-backed)
BCRYPT_ROUNDS="12"              # production minimum; 10 is acceptable in dev

# ---- Server ------------------------------------------------------------
PORT="8000"
NODE_ENV="development"          # runtime mode: development | production
APP_ENV="local"                 # env label: local | staging | production
API_VERSION="v1"

# Comma-separated list of allowed origins for CORS (REST + Socket.IO).
# Must NOT be "*" in any deployed environment.
CORS_ORIGINS="http://localhost:3000"

# ---- Business logic ----------------------------------------------------
# Hours after `awaiting_customer_confirmation` before auto-release fires.
AUTO_RELEASE_HOURS="48"

# ---- Observability (populated once Sentry / Grafana are set up) -------
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="local"

# Grafana Cloud — Loki/Mimir/Tempo via OTLP
# LOKI_URL=""
# LOKI_USER=""
# GRAFANA_API_KEY=""
# OTEL_EXPORTER_OTLP_ENDPOINT=""
# OTEL_EXPORTER_OTLP_HEADERS=""
